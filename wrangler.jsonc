{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "textil-cabrera",
  "assets": {
    "directory": "./out",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "compatibility_date": "2025-09-27",
  "routes": [
    {
      "pattern": "textilcabrera.com.uy",
      "custom_domain": true
    }
  ]
}
